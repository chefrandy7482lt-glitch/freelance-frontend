<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>TDU Freelance – Real Engine</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; padding: 20px; background: #0b1020; color: #f5f5f5; }
    h1 { margin-bottom: 8px; }
    .subtitle { color: #9aa0b8; margin-bottom: 20px; }
    textarea { width: 100%; height: 140px; padding: 10px; border-radius: 6px; border: 1px solid #333; background: #111528; color: #f5f5f5; resize: vertical; }
    button { margin-top: 12px; padding: 10px 18px; border-radius: 6px; border: none; background: #3b82f6; color: white; font-weight: 600; cursor: pointer; }
    button:disabled { background: #1f2937; cursor: default; }
    .status { margin-top: 10px; font-size: 0.9rem; color: #9aa0b8; }
    .output { margin-top: 18px; padding: 12px; border-radius: 6px; background: #111528; border: 1px solid #1f2937; white-space: pre-wrap; font-size: 0.95rem; }
    .error { color: #f97373; }
  </style>
</head>
<body>
  <h1>TDU Freelance – Direct Engine Call</h1>
  <div class="subtitle">
    This screen talks to your Cloudflare Worker for real. No simulation.
  </div>

  <label for="jobInput">Job / prompt:</label>
  <textarea id="jobInput" placeholder="Example: tell me about the different types of files in the computer"></textarea>

  <button id="runJobBtn">Run job through Worker</button>
  <div id="status" class="status"></div>
  <div id="output" class="output"></div>

  <script>
    const WORKER_URL = "https://tdu-freelance-backend.tdu-freelance.workers.dev/file/summarize";

    const jobInput = document.getElementById("jobInput");
    const runJobBtn = document.getElementById("runJobBtn");
    const statusEl = document.getElementById("status");
    const outputEl = document.getElementById("output");

    async function runJob() {
      const text = jobInput.value.trim();
      if (!text) {
        statusEl.textContent = "Enter a job or prompt first.";
        return;
      }

      runJobBtn.disabled = true;
      statusEl.textContent = "Sending job to Worker...";
      outputEl.textContent = "";

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text })
        });

        if (!res.ok) {
          statusEl.textContent = "Worker returned an error (" + res.status + ").";
          const errText = await res.text();
          outputEl.textContent = errText;
          runJobBtn.disabled = false;
          return;
        }

        const data = await res.json();
        statusEl.textContent = "Job completed.";
        outputEl.textContent = JSON.stringify(data, null, 2);
      } catch (e) {
        statusEl.textContent = "Network or Worker error.";
        outputEl.textContent = String(e);
      } finally {
        runJobBtn.disabled = false;
      }
    }

    runJobBtn.addEventListener("click", runJob);
  </script>
</body>
</html>
